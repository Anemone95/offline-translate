<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFFFF"
    android:padding="16dp">

    <TextView
        android:id="@+id/transcript_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/label_transcript"
        android:textColor="#FF000000"
        android:textSize="16sp"
        android:textStyle="bold"
        android:paddingBottom="6dp" />

    <TextView
        android:id="@+id/my_text"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FFFFFFFF"
        android:padding="12dp"
        android:scrollbars="vertical"
        android:singleLine="false"
        android:textColor="#FF000000"
        android:textSize="22sp"
        android:textIsSelectable="true"
        android:text="@string/hint" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#FF000000"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/translation_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/label_translation"
        android:textColor="#FF000000"
        android:textSize="16sp"
        android:textStyle="bold"
        android:paddingBottom="6dp" />

    <TextView
        android:id="@+id/translation_text"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FFFFFFFF"
        android:padding="12dp"
        android:scrollbars="vertical"
        android:singleLine="false"
        android:textColor="#FF000000"
        android:textSize="22sp"
        android:textIsSelectable="true"
        android:text="@string/translation_placeholder" />

    <Button
        android:id="@+id/record_button"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginTop="16dp"
        android:textSize="18sp"
        android:textStyle="bold"
        android:text="@string/start" />

</LinearLayout>
