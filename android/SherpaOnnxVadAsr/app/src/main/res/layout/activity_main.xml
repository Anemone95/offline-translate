<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFFFF">

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tab_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFFFF"
        app:tabMode="fixed"
        app:tabGravity="fill"
        app:tabIndicatorColor="#FF000000"
        app:tabIndicatorHeight="2dp"
        app:tabSelectedTextColor="#FF000000"
        app:tabTextColor="#FF000000"
        app:tabTextAppearance="@style/TabText">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tab_speech" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tab_translate" />
    </com.google.android.material.tabs.TabLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_model"
            android:textColor="#FF000000"
            android:textSize="16sp"
            android:textStyle="bold"
            android:paddingEnd="12dp" />

        <Spinner
            android:id="@+id/model_spinner"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="#FFFFFFFF" />
    </LinearLayout>

    <TextView
        android:id="@+id/transcript_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/label_transcript"
        android:textColor="#FF000000"
        android:textSize="16sp"
        android:textStyle="bold"
        android:paddingBottom="6dp" />

    <ScrollView
        android:id="@+id/transcript_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <EditText
            android:id="@+id/my_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFFFF"
            android:padding="12dp"
            android:singleLine="false"
            android:gravity="top|start"
            android:inputType="textMultiLine"
            android:textColor="#FF000000"
            android:textSize="22sp"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:cursorVisible="false"
            android:text="@string/hint" />
    </ScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#FF000000"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/translation_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/label_translation"
        android:textColor="#FF000000"
        android:textSize="16sp"
        android:textStyle="bold"
        android:paddingBottom="6dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <TextView
            android:id="@+id/translation_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFFFF"
            android:padding="12dp"
            android:singleLine="false"
            android:textColor="#FF000000"
            android:textSize="22sp"
            android:textIsSelectable="true"
            android:text="@string/translation_placeholder" />
    </ScrollView>

    <Button
        android:id="@+id/record_button"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginTop="16dp"
        android:textSize="18sp"
        android:textStyle="bold"
        android:enabled="false"
        android:text="@string/start" />

    </LinearLayout>

</LinearLayout>
